<% if (expand){ %>
  <% page.posts.each(function(post){ %>
    <%- partial('article', {post: post, index: true}) %>
  <% }) %>
<% } else { %>
  <% 
    // 按日期倒序排列（从新到旧）
    var sortedPosts = page.posts.toArray().sort(function(a, b) {
      return b.date - a.date;
    });
  %>
  <% var lastYear, lastMonth; %>
  <% sortedPosts.forEach(function(post, i){ %>
    <% var year = post.date.year(); %>
    <% var month = post.date.month() + 1; %>
    <% if (lastYear != year || lastMonth != month){ %>
      <% if (lastYear != null){ %>
        </div></section>
      <% } %>
      <% lastYear = year; %>
      <% lastMonth = month; %>
      <section class="archives-wrap">
        <div class="archive-year-wrap">
          <a href="<%- url_for(config.archive_dir + '/' + year + '/' + month) %>" class="archive-year"><%= year %>年<%= month %>月</a>
        </div>
        <div class="archives">
    <% } %>
    <%- partial('archive-post', {post: post, even: i % 2 == 0}) %>
  <% }) %>
  <% if (sortedPosts.length){ %>
    </div></section>
  <% } %>
<% } %>
<% if (page.total > 1 && expand){ %>
  <nav id="page-nav">
    <% var prev_text = "&laquo; " + __('prev');var next_text = __('next') + " &raquo;"%>
    <%- paginator({
      prev_text: prev_text,
      next_text: next_text,
      escape: false
    }) %>
  </nav>
<% } %>
